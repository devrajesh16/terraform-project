# Copy this file to terraform.tfvars (git-ignored) and fill in real values.
# NEVER commit terraform.tfvars — it contains secrets.

aws_region   = "us-east-1"
project_name = "mycompany"
domain_name  = "example.com"

vpc_cidr             = "10.0.0.0/16"
availability_zones   = ["us-east-1a", "us-east-1b", "us-east-1c"]
public_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24", "10.0.3.0/24"]
private_subnet_cidrs = ["10.0.11.0/24", "10.0.12.0/24", "10.0.13.0/24"]

kubernetes_version = "1.30"

db_name     = "appdb"
db_username = "appuser"
db_password = "CHANGE_ME_use_aws_secrets_manager"

alert_emails = ["devops-team@example.com"]
